# =============================================================================
# Gateway — Local Development Environment
# =============================================================================

NODE_ENV=development
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3100

# Redis（本地 Docker 或本机实例）
REDIS_URL=redis://127.0.0.1:6379

# JWT（需与签发 Token 的服务一致）
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ISSUER=ai-platform
JWT_ACCESS_TOKEN_TTL=7200

# Agent Core（本地 uvicorn 端口）
AGENT_CORE_API_URL=http://127.0.0.1:8002

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 企业微信（本地开发占位即可，Bot 长连接留空则跳过）
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_SECRET=your-secret
WECOM_BOT_WS_URL=
WECOM_BOT_WS_AUTH_TOKEN=

LOG_LEVEL=debug
